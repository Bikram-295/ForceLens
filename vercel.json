{
  "version": 2,
  "builds": [
    {
      "src": "cf_profile_analyzer/cf_profile_analyzer/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles-cdn"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "cf_profile_analyzer/cf_profile_analyzer/wsgi.py"
    }
  ]
}
